{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/profile",
      "dest": "/api/profile.py"
    },
    {
      "src": "/api/download",
      "dest": "/api/download.py"
    },
    {
      "src": "/api/upload",
      "dest": "/api/upload.py"
    },
    {
      "src": "/api/token",
      "dest": "/api/token.py"
    },
    {
      "src": "/api/test_keys",
      "dest": "/api/test_keys.py"
    },
    {
      "src": "/auth-callback",
      "dest": "/public/auth-callback.html"
    },
    {
      "src": "/api/storage",
      "dest": "/api/storage.py"
    },
    {
      "src": "/api/settings",
      "dest": "/api/settings.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}