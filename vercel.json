{
  "version": 2,
  "functions": {
    "api/upload.py":    { "runtime": "python3.9", "maxDuration": 60 },
    "api/profile.py":   { "runtime": "python3.9", "maxDuration": 30 },
    "api/download.py":  { "runtime": "python3.9", "maxDuration": 15 },
    "api/storage.py":   { "runtime": "python3.9", "maxDuration": 30 },
    "api/test_keys.py": { "runtime": "python3.9", "maxDuration": 30 },
    "api/token.py":     { "runtime": "python3.9", "maxDuration": 15 },
    "api/settings.py":  { "runtime": "python3.9", "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/profile",   "dest": "/api/profile.py"   },
    { "src": "/api/download",  "dest": "/api/download.py"  },
    { "src": "/api/upload",    "dest": "/api/upload.py"    },
    { "src": "/api/token",     "dest": "/api/token.py"     },
    { "src": "/api/test_keys", "dest": "/api/test_keys.py" },
    { "src": "/api/storage",   "dest": "/api/storage.py"   },
    { "src": "/api/settings",  "dest": "/api/settings.py"  },
    { "src": "/auth-callback", "dest": "/public/auth-callback.html" },
    { "src": "/(.*)",          "dest": "/public/index.html" }
  ]
}
